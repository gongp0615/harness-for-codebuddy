{
  "description": "Harness Engineer hooks for CodeBuddy Code CLI.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CODEBUDDY_PLUGIN_ROOT}/hooks/session-start.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CODEBUDDY_PLUGIN_ROOT}/hooks/pre-tool-use.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CODEBUDDY_PLUGIN_ROOT}/hooks/post-tool-use.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CODEBUDDY_PLUGIN_ROOT}/hooks/stop.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CODEBUDDY_PLUGIN_ROOT}/hooks/pre-compact.js"
          }
        ]
      }
    ]
  }
}
